<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pra.MainPage"
             >
    <Grid RowDefinitions="Auto,*,Auto"
          >

        <Grid BackgroundColor="#40C95A"
              HeightRequest="80"
              Padding="15,10">
            <Image Source="logo.png"
                   HeightRequest="370"
                   WidthRequest="400"
                   VerticalOptions="Start"
                   HorizontalOptions="Start"/>

            <Label Text="Главная"
                   TextColor="White"
                   FontSize="58"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontFamily="Finlandica"/>
        </Grid>


        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20"
                                 Spacing="30">


                <Border StrokeThickness="0"
                        WidthRequest="450"
                        HeightRequest="100">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                             EndPoint="1,0">
                            <GradientStop Color="#BFFEA8" Offset="0" />
                            <GradientStop Color="#C2EF46" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Процесс"
                               FontSize="48"
                               HorizontalOptions="Center"
                               TextColor="#333"
                               FontFamily="Finlandica"/>
                        <ScrollView>
                            <ProgressBar x:Name="MyProgressBar"
                                         Progress="0.5"
                                         WidthRequest="400"
                                         HeightRequest="10"
                                         HorizontalOptions="Fill"
                                         ProgressColor="Green"/>
                        </ScrollView>

                    </VerticalStackLayout>

                </Border>


                <Grid ColumnDefinitions="120,*">


                    <Image Source="gir.png"
                           HeightRequest="370"
                           WidthRequest="400"
                           VerticalOptions="End"/>


                    <VerticalStackLayout
                        Margin="0 0 0 13"
                        Grid.Column="1"
                        Spacing="15"
                        VerticalOptions="Center">

                        <Label Text="Изучаем"
                               FontSize="48"
                               HorizontalTextAlignment="Start"
                               FontFamily="Finlandica"/>

                        <Label Text="английский"
                               FontSize="48"
                               HorizontalTextAlignment="Center"
                               FontFamily="Finlandica"/>

                        <Label Text="ВМЕСТЕ"
                               FontSize="48"
                               TextColor="#40C95A"
                               HorizontalTextAlignment="Center"
                               FontFamily="Finlandica"
                               FontAttributes="Bold"/>

                        <Button Text="START"
                                FontSize="55"
                                FontAttributes="Bold"
                                TextColor="#F6FFD9"
                                BackgroundColor="#45EA63"
                                CornerRadius="35"
                                HeightRequest="90"
                                WidthRequest="250"
                                HorizontalOptions="Center"
                                FontFamily="Finlandica"
                                Clicked="OnButtonClicked"/>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
