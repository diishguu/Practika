<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pra.Pages.Profile"
             Title="Profile"
             BackgroundColor="{StaticResource Cream}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <!--Профиль-->
            <Border BackgroundColor="{StaticResource Emerald}"
                StrokeShape="RoundRectangle 20"
                Stroke="Transparent"
                Padding="20">
                <Grid ColumnDefinitions="Auto, *"
                  ColumnSpacing="16">
                    <Border WidthRequest="64" HeightRequest="64"
                        StrokeShape="RoundRectangle 32"
                        Stroke="Transparent"
                        BackgroundColor="{StaticResource AcidGreen}">
                        <Label Text="П"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Dark}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center"
                                     Spacing="2">
                        <Label Text="Имя пользователя: "
                           FontSize="20"
                           FontAttributes="Bold"/>
                        <Label Text="Уровень: Inter"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Cream}"
                           Opacity="0"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>
            <!--Настройки-->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 18"
                Stroke="Transparent" Padding="0">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*, Auto" Padding="16, 14">
                        <Label Text="Изучаемый язык" TextColor="{StaticResource Dark}"
                           VerticalOptions="Center"/>
                        <Picker Grid.Column="1" SelectedIndex="0" WidthRequest="140"
                            TextColor="{StaticResource Emerald}">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Английский</x:String>
                                    <x:String>Немецкий</x:String>
                                    <x:String>Французский</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Cream}"/>
                    <Grid ColumnDefinitions="*, Auto" Padding="16, 14" ColumnSpacing="8">
                        <Label Text="Ежедневная цель" 
                           TextColor="{StaticResource Dark}"
                           VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="20 слов" TextColor="{StaticResource Emerald}"
                           FontAttributes="Bold" VerticalOptions="Center"/>
                        <Stepper Grid.Column="2" Minimum="5" Maximum="100"
                             Increment="5" Value="20"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Cream}"/>
                    <Grid ColumnDefinitions="*, Auto" Padding="16, 14" ColumnSpacing="8">
                        <Label Text="Уведомления" 
                           TextColor="{StaticResource Dark}"
                           VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="False"
                            OnColor="{StaticResource LightGreen}"
                            ThumbColor="{StaticResource Cream}"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Cream}"/>
                    <Grid ColumnDefinitions="*, Auto" Padding="16, 14" ColumnSpacing="8">
                        <Label Text="Темная тема" 
                            TextColor="{StaticResource Dark}"
                            VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="False"
                            OnColor="{StaticResource LightGreen}"
                            ThumbColor="{StaticResource Cream}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
            <!--кнопка сброса прогресса-->
            <Button Text="Сбросить прогресс"
                BackgroundColor="{StaticResource Dark}"
                TextColor="{StaticResource Cream}"
                CornerRadius="16" HeightRequest="52" FontAttributes="Bold"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>